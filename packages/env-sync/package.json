{
  "name": "@hardmachinelabs/env-sync",
  "version": "1.0.0",
  "description": "Sync .env files to CI/CD secrets — GitLab & GitHub, monorepo-aware",
  "author": "Jordach Makaya <hello@jordach.dev> (https://jordach.dev)",
  "license": "MIT",
  "homepage": "https://github.com/jordachmakaya/env-sync#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jordachmakaya/env-sync.git"
  },
  "bugs": {
    "url": "https://github.com/jordachmakaya/env-sync/issues"
  },
  "keywords": [
    "env",
    "dotenv",
    "secrets",
    "gitlab",
    "github",
    "ci",
    "monorepo",
    "devops",
    "cli"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "env-sync": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "pack:dry-run": "npm pack --dry-run --json",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "dotenv": "16.6.1"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
